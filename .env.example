# Auth: API key for accessing the MCP server
# Generate a random key:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Hash it for this var:    echo -n "YOUR_KEY" | shasum -a 256 | cut -d' ' -f1
API_KEY_HASH=

# Optional: Database URL (defaults to local Docker Compose Postgres)
DATABASE_URL=postgresql://claude_sync:claude_sync_dev@localhost:5432/claude_sync

# Optional: Server port (default 3001)
PORT=3001

# Optional: Postgres password for Docker Compose
POSTGRES_PASSWORD=claude_sync_dev

# Optional: Embedding model (default: Xenova/all-MiniLM-L6-v2, runs locally)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Optional: Embedding dimensions (default 384 for all-MiniLM-L6-v2)
EMBEDDING_DIMENSIONS=384

# Optional: Default project name for single-key mode
DEFAULT_PROJECT=default
